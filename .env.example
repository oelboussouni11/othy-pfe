# Postgres (used by docker-compose and backend)
# If you already have Postgres on 5432 locally, set POSTGRES_PORT=5433 (or any free port) and
# update DB_URL to match.
POSTGRES_USER=smartlaunchqa
POSTGRES_PASSWORD=smartlaunchqa
POSTGRES_DB=smartlaunchqa
POSTGRES_PORT=5432
DB_URL=postgresql+psycopg://smartlaunchqa:smartlaunchqa@localhost:5432/smartlaunchqa

# Redis (used by backend + RQ worker)
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=dev-only-change-this-secret-to-32-plus-random-bytes-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_MIN=15
JWT_REFRESH_TOKEN_TTL_DAYS=7

# Backend
BACKEND_CORS_ORIGINS=http://localhost:3000
ENVIRONMENT=development
LOG_LEVEL=INFO

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
